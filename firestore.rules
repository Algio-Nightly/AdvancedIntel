rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: User is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: User owns the resource
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User Profiles & Private Telemetry
    match /Users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
      
      // Historical Telemetry Snapshots
      match /TelemetrySnapshots/{date} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
    }

    // Research Projects
    match /Projects/{projectId} {
      allow create: if isSignedIn() && isOwner(request.resource.data.uid);
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.uid);
    }

    // Knowledge Nodes
    match /Nodes/{nodeId} {
      allow create: if isSignedIn() && isOwner(request.resource.data.uid);
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.uid);
    }

    // Library Metadata
    match /LibraryArchive/{docId} {
      allow create: if isSignedIn() && isOwner(request.resource.data.uid);
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.uid);
    }

    // Document Specific Notes
    match /DocumentNotes/{noteId} {
      allow read, write: if isSignedIn() && isOwner(request.auth.uid);
    }
  }
}
